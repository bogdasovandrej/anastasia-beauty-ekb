{
  "buildCommand": "echo 'No build required'",
  "outputDirectory": ".",
  "installCommand": "echo 'No dependencies'",
  "devCommand": "echo 'No dev server needed'",
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, must-revalidate"
        }
      ]
    }
  ]
}